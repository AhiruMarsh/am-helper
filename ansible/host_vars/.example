# Required
hostname: string

# Optional
# OS: users
users:
  - name: string
    uid: number
    password: hashed string
    groups: string

# common-apps (prom-node-exporter)
cloudflared_token: string

# project: obs
o11y_cloudflared_token: string
o11y_prom_client_secret_token: string
o11y_alertmanager_username: string
o11y_alertmanager_password: string

o11y_exporter_cloudflare_cf_accounts: string
o11y_exporter_cloudflare_cf_api_token: string

# project: kuma (obs)
kuma_cloudflared_token: string

# project: rpx
rpx_client_secret_token: string

# project: mc
mc_version: string
mc_type: string
mc_hardcore_enabled: bool
mc_plugins_list: list<string>
mc_mods_list: list<string>
mc_join_fqdn: string
mc_dynmap_fqdn: string
mc_discordsrv_bot_token_id: string
mc_discordsrv_channel_broadcast_id: string
mc_discordsrv_channel_console_id: string
mc_cloudflared_token: string
